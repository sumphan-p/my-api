{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=AuthAPI;Trusted_Connection=true;TrustServerCertificate=true;"
  },
  "Jwt": {
    "Issuer": "auth.king-pac.com",
    "Audience": "king-pac-apps",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Security": {
    "BcryptWorkFactor": 12,
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15,
    "PasswordResetExpiryMinutes": 60
  },
  "Email": {
    "Host": "mail.king-pac.com",
    "Port": 587,
    "FromAddress": "noreply@king-pac.com",
    "RetryCount": 3
  },
  "TokenCleanup": {
    "IntervalHours": 24,
    "InitialDelaySeconds": 10,
    "AuditLogRetentionDays": 90
  },
  "RateLimit": {
    "PermitLimit": 5,
    "WindowMinutes": 1
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000"
    ]
  }
}
